# Core Configuration
NODE_ENV=production
BOT_MODE=LIVE
# LLM_MODE=claude → utilise l'API Anthropic (pas Playwright/Chrome) sur VPS headless
LLM_MODE=claude

# Administration & Security
# Format: telegramUserId:ROLE (valid roles: VIEWER, OPERATOR, TRADER, ADMIN)
ADMIN_ROLES=123456789:ADMIN,987654321:OPERATOR
MINI_APP_URL=https://your-miniapp-domain.com

# MCP Service (PerpEdge Core)
PERP_MCP_URL=https://your-perp-mcp-endpoint.com
PERP_MCP_TOKEN=your_perp_mcp_token_here

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# Scheduler & Strategy
CRON_SCHEDULE=0 * * * *
MIN_SCORE=6.0
POSITION_SIZE_USDT=100

# Anthropic API (LLM Validator)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Binance Futures (production — BINANCE_TESTNET=false)
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE
BINANCE_TESTNET=false
