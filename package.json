{
  "name": "perpedge-bot",
  "version": "1.0.0",
  "description": "Autonomous PerpEdge trading signal bot",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "deploy:check": "node scripts/deploy-prod.js",
    "deploy:ssh": "bash scripts/deploy-ssh.sh",
    "deploy:ssh:fast": "bash scripts/deploy-ssh.sh --skip-miniapp",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:ui": "vitest --ui --workspace vitest.workspace.ts",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "grammy": "^1.42.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.60.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "vitest": "^2.1.9"
  }
}
